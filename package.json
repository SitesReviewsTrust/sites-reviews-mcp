    "dist",
    "examples",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "node --import tsx test/sites-reviews.test.ts",
    "prepublishOnly": "npm run build"
